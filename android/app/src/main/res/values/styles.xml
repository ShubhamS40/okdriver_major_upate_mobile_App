<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base Flutter launch theme -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>

    <!-- Normal app theme after launch -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>

    <!--
        ✅ CRITICAL: BackgroundAssistantActivity ke liye translucent theme
        - windowIsTranslucent = true → background dikh sakta hai
        - windowIsFloating = false → full width milti hai
        - windowBackground = transparent → apna background draw karega
        - showWhenLocked = true → lock screen ke upar bhi dikhega
        - turnScreenOn = true → screen ON ho jaata hai
    -->
    <style name="Theme.Translucent" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.75</item>
        <!-- ✅ Lock screen ke upar dikhne ke liye -->
        <item name="android:showWhenLocked">true</item>
        <item name="android:turnScreenOn">true</item>
    </style>

</resources>